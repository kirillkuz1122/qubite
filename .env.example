# Core app
HOST=127.0.0.1
PORT=3000
APP_BASE_URL=http://127.0.0.1:3000
NODE_ENV=dev
DATABASE_PATH=/home/kirill/programing/qubite/back/data/qubite.sqlite

# Reverse proxy / same-origin protection
# 0/false  - do not trust proxy headers
# 1/true   - trust loopback/linklocal/uniquelocal reverse proxy
# or a custom Express trust proxy value
TRUST_PROXY=0
ALLOWED_ORIGINS=http://127.0.0.1:3000
ALLOWED_HOSTS=127.0.0.1

# Sessions
SESSION_COOKIE_NAME=qb_session
SESSION_TOUCH_INTERVAL_MS=300000

# Request parsing / connection hardening
JSON_BODY_LIMIT=32kb
HEAVY_JSON_BODY_LIMIT=256kb
IMPORT_JSON_BODY_LIMIT=2mb
REQUEST_TIMEOUT_MS=15000
HEADERS_TIMEOUT_MS=12000
KEEP_ALIVE_TIMEOUT_MS=5000
MAX_REQUESTS_PER_SOCKET=100
SQLITE_BUSY_TIMEOUT_MS=5000
SEED_DEMO_DATA=false

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
# Development only. Do not enable in production.
TURNSTILE_DEV_BYPASS=true

# Email delivery
# log      - dev mode, письма выводятся в консоль сервера
# disabled - письма не отправляются
# resend   - реальные письма через Resend API
EMAIL_DELIVERY_MODE=resend
EMAIL_FROM=Qubite <no-reply@example.com>
EMAIL_REPLY_TO=support@example.com
RESEND_API_KEY=

# ─── OAuth провайдеры ───
# Если CLIENT_ID и CLIENT_SECRET пусты, кнопка провайдера скрывается автоматически.
# CALLBACK_URL должен совпадать с тем, что указан в консоли провайдера.

# Google OAuth
# 1. Перейти: https://console.cloud.google.com/apis/credentials
# 2. «Create Credentials» → «OAuth client ID» → тип «Web application»
# 3. В «Authorized redirect URIs» добавить GOOGLE_CALLBACK_URL
# 4. Скопировать Client ID и Client Secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://qubiteapp.ru/api/auth/oauth/google/callback

# Yandex OAuth
# 1. Перейти: https://oauth.yandex.ru/client/new
# 2. Создать приложение, выбрать «Веб-сервисы» → «Callback URL» = YANDEX_CALLBACK_URL
# 3. Права: «login:email», «login:info», «login:avatar»
# 4. Скопировать ID и Пароль приложения
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=https://qubiteapp.ru/api/auth/oauth/yandex/callback

# VK ID SDK (client-side авторизация, secret не нужен)
# 1. Перейти: https://id.vk.com/about/business/go → Создать приложение
# 2. Тип: «Веб-сайт», указать адрес и домен
# 3. В настройках → «Redirect URI» → https://<домен>/api/auth/oauth/vk/callback
# 4. Скопировать «ID приложения» (число)
VK_APP_ID=

# Telegram Bot & Login Widget
# 1. Получить токен: https://t.me/BotFather → /newbot
# 2. Для Login Widget: BotFather → /mybots → Bot Settings → Domain → добавить домен сайта
TELEGRAM_BOT_TOKEN=
# Telegram user ID владельца платформы (только он имеет полный доступ к боту)
TELEGRAM_OWNER_ID=
# Дополнительные модераторы (CSV telegram user IDs). Динамические выдачи — через /grant в боте.
TELEGRAM_MODERATOR_IDS=
# true/false — включить/выключить бота (по умолчанию true, если задан токен)
TELEGRAM_ENABLED=false
