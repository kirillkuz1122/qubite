# Core app
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=https://qubiteapp.ru
NODE_ENV=development

# Sessions
SESSION_COOKIE_NAME=qb_session

# Admin bootstrap
# Любой пользователь с этим логином/почтой получит роль admin
ADMIN_LOGINS=admin
ADMIN_EMAILS=

# Email delivery
# log      - dev mode, письма выводятся в консоль сервера
# disabled - письма не отправляются
# resend   - реальные письма через Resend API
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=Qubite <no-reply@example.com>
EMAIL_REPLY_TO=support@example.com
RESEND_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:3000/api/auth/oauth/google/callback

# Yandex OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=http://127.0.0.1:3000/api/auth/oauth/yandex/callback
